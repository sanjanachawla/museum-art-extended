{
  "family": "museum-art-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<account-id>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<account-id>:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "<account-id>.dkr.ecr.<region>.amazonaws.com/museum-art-api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "command": ["python", "-m", "scripts.start_api"],
      "environment": [
        { "name": "DB_HOST", "value": "<rds-endpoint>" },
        { "name": "DB_USER", "value": "<db-user>" },
        { "name": "DB_NAME", "value": "met_art" },
        { "name": "DB_PORT", "value": "3306" },
        { "name": "API_HOST", "value": "0.0.0.0" },
        { "name": "API_PORT", "value": "8000" },
        { "name": "RUN_DB_INIT_ON_STARTUP", "value": "true" },
        { "name": "CREATE_DB_IF_MISSING", "value": "false" }
      ],
      "secrets": [
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:<db-password-secret>"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health', timeout=5)\" || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/museum-art-api",
          "awslogs-region": "<region>",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
